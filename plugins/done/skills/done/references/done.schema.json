{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "done quality-gate configuration",
  "type": "object",
  "required": ["version", "repo", "verify"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": 1},
    "repo": {"type": "string", "minLength": 1},
    "verify": {
      "type": "object",
      "required": ["quick", "standard", "full"],
      "additionalProperties": false,
      "properties": {
        "quick": {"$ref": "#/$defs/commands"},
        "standard": {"$ref": "#/$defs/commands"},
        "full": {"$ref": "#/$defs/commands"}
      }
    },
    "tier_floors": {"type": "object"},
    "docs": {"type": "object"},
    "review": {"type": "object"}
  },
  "$defs": {
    "commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
